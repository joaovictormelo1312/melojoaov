# 3. Função de Cross-Attention
def cross_attention(encoder_out, decoder_state):
    # Projeções lineares usando matrizes de pesos arbitrárias
    W_q = torch.randn(d_model, d_model)
    W_k = torch.randn(d_model, d_model)
    W_v = torch.randn(d_model, d_model)
    
    # Projeta decoder_state para virar a Query (Q)
    Q = torch.matmul(decoder_state, W_q)
    
    # Projeta encoder_out para virar as Keys (K) e Values (V)
    K = torch.matmul(encoder_out, W_k)
    V = torch.matmul(encoder_out, W_v)
    
    # 4. Equação do Scaled Dot-Product Attention (sem máscara causal)
    scores = torch.matmul(Q, K.transpose(-2, -1)) / math.sqrt(d_model)
    attention_weights = F.softmax(scores, dim=-1)
    
    output = torch.matmul(attention_weights, V)
    return output

saida_cross_attention = cross_attention(encoder_output, decoder_state)
