import torch
import torch.nn.functional as F
import math

# 1. e 2. Função para criar a máscara causal
def create_causal_mask(seq_len):
    # Cria uma matriz de uns e zera a parte triangular inferior e a diagonal
    mask = torch.triu(torch.ones(seq_len, seq_len), diagonal=1)
    # Substitui os uns por -infinito e o resto por zero
    mask = mask.masked_fill(mask == 1, float('-inf'))
    return mask

